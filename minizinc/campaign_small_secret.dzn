% Campaign: Small Secret (256 bytes)
% Use case: Private key, seed phrase, short message
% Strategy: Cheap social media spread with Golay ECC

payload_bytes = 256;
ecc_mode = 2;           % Golay [24,12,8] — Voyager-grade
redundancy_factor = 2;  % 2× redundancy for critical secret
max_shards_total = 30;

num_platforms = 7;

platform_name = ["tweet280", "discord", "instagram", "tiktok", "solana-memo", "mastodon", "bluesky"];
capacity     = [55,         972,       537,         537,       558,           112,        60];
max_carriers = [10,         5,         5,           5,         10,            5,          5];
cost_microusd = [0,         0,         0,           0,         10000,         0,          0];
% Social media posts are free. Solana memo = ~$0.01/tx = 10000 µ$
